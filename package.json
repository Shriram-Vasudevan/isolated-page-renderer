{
  "name": "state-render",
  "version": "0.1.0",
  "description": "State-Synthesized UI Renderer - Render any page or component in isolation by automatically mocking all required inputs",
  "main": "dist/index.js",
  "bin": {
    "state-render": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "nextjs",
    "isolated-rendering",
    "mock",
    "developer-tool",
    "preview"
  ],
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "esbuild": "^0.20.0",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3"
  }
}
